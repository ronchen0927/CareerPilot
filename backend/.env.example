# Copy this file to .env and fill in the values:
#   cp .env.example .env

# OpenAI API key — required for AI job evaluation (/evaluate page)
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Debug mode — set to false in production
DEBUG=true

# CORS allowed origins — restrict in production, e.g. http://localhost:5173
# CORS_ORIGINS=["http://localhost:5173"]
